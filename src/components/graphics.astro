---
const charts = [
  { title: "Diversificación por tipo", type: "diversificacion" },
  { title: "Historial del valor del portafolio", type: "historial_valores" },
  { title: "Historial de aportes", type: "historial_aportes" },
  { title: "Rendimientos diarios", type: "rendimientos" },
  { title: "Evolución por tipo de cuenta", type: "evolucion_por_tipo" },
  { title: "Ingresos vs egresos", type: "ingresos_vs_egresos" },
  { title: "Comparativa COP vs USD", type: "comparativa_cop_usd" },
  { title: "Rentabilidad acumulada", type: "rentabilidad_acumulada" },
  { title: "Rendimiento porcentual diario", type: "rendimiento_porcentual" },
];
---

<style>
  .grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    padding: 1rem;
  }

  .card {
    background: white;
    border-radius: 14px;
    padding: 1rem;
    box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    border: 1px solid #eee;
  }

  .card img {
    max-width: 100%;
    border-radius: 10px;
  }

  h2 {
    font-size: 1.3rem;
    margin-bottom: 0.8rem;
    font-weight: 600;
  }
</style>

<div class="grid">
  {charts.map(chart => (
    <div class="card">
      <h2>{chart.title}</h2>
      <img src={`/api/graphics?type=${chart.type}`} alt={chart.title} />
    </div>
  ))}
</div>
