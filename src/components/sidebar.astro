    ---
    interface Props {
        activePage: string;
    }
    const { activePage } = Astro.props;
    ---
    <aside class="fixed left-0 top-0 h-screen w-64 bg-slate-900 text-white flex flex-col shadow-xl z-50">
      <!-- Logo / Header -->
      <div class="p-6 border-b border-slate-700">
        <h2 class="text-2xl font-bold text-blue-400">Portfolio</h2>
        <p class="text-xs text-slate-400 mt-1">Investment Manager</p>
      </div>

      <!-- Navigation -->
      <nav class="flex-1 p-4 space-y-2">
        <a href="/admin" class={`flex items-center gap-3 px-4 py-3 rounded-lg text-white font-medium ${activePage === 'dashboard' ? 'bg-slate-800' : 'hover:bg-slate-800 text-slate-300 hover:text-white'} transition`}>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
          </svg>
          Dashboard
        </a>

        <a href="/admin/contribute" class={`flex items-center gap-3 px-4 py-3 rounded-lg text-white font-medium ${activePage === 'contribute' ? 'bg-slate-800' : 'hover:bg-slate-800 text-slate-300 hover:text-white'} transition`}>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
          </svg>
          Agregar Fondos
        </a>

        <a href="/admin/withdraw" class={`flex items-center gap-3 px-4 py-3 rounded-lg text-white font-medium ${activePage === 'whitdraw' ? 'bg-slate-800' : 'hover:bg-slate-800 text-slate-300 hover:text-white'} transition`}>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/>
          </svg>
          Retirar Fondos
        </a>

        <a href="/admin/accounts" class={`flex items-center gap-3 px-4 py-3 rounded-lg text-white font-medium ${activePage === 'accounts' ? 'bg-slate-800' : 'hover:bg-slate-800 text-slate-300 hover:text-white'} transition`}>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
          </svg>
          Cuentas
        </a>

        <a href="/admin/history" class={`flex items-center gap-3 px-4 py-3 rounded-lg text-white font-medium ${activePage === 'history' ? 'bg-slate-800' : 'hover:bg-slate-800 text-slate-300 hover:text-white'} transition`}>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Historial
        </a>
      </nav>

      <!-- User Section -->
      <div class="p-4 border-t border-slate-700">
        <a href="/api/auth/logout" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-slate-800 text-slate-300 hover:text-red-400 transition">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
          </svg>
          Cerrar Sesión
        </a>
      </div>
    </aside>