---
import "@styles/global.css";

interface Props {
  title?: string;
}

const { title } = Astro.props;
---
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>

  <body class="min-h-screen flex bg-slate-900 text-white">
    <slot />
  </body>
</html>