---
import Layout from "@layouts/default.astro";
import Sidebar from "@components/sidebar.astro";
import { sql } from "@lib/db";

const userId = Astro.locals.userId;

if (!userId) {
  // Asegúrate de que solo los usuarios logueados puedan acceder
  return Astro.redirect("/auth/login?returnTo=/admin/update-rate");
}

let message: { type: 'success' | 'error', text: string } | null = null;
let latestRate = 'N/A';
let latestDate = 'N/A';

// Obtener la tasa de cambio actual para mostrar
const rates = await sql`
  SELECT usd_to_cop, date
  FROM exchange_rates
  ORDER BY date DESC
  LIMIT 1;
`;

if (rates.length > 0) {
  latestRate = Number(rates[0].usd_to_cop).toLocaleString('es-CO');
  latestDate = new Date(rates[0].date).toLocaleDateString('es-CO', { dateStyle: 'medium' });
}


// ----------------------
// Manejo de la Petición POST
// ----------------------
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const newRate = formData.get("new_rate");
    const dateStr = formData.get("rate_date");

    if (!newRate || !dateStr) {
      throw new Error("El valor de la tasa y la fecha son obligatorios.");
    }
    
    const rateValue = Number(newRate);
    if (isNaN(rateValue) || rateValue <= 0) {
      throw new Error("La tasa de cambio debe ser un número positivo.");
    }

    // Insertar el nuevo valor en la tabla exchange_rates
    await sql`
      INSERT INTO exchange_rates (date, usd_to_cop)
      VALUES (${dateStr}, ${rateValue});
    `;

    // Redirigir para limpiar el formulario y mostrar el mensaje de éxito
    return Response.redirect("/admin/exchange?success=1"), 303;

  } catch (e) {
    console.error("Error al actualizar la tasa de cambio:", e);
    const errorMsg = e instanceof Error ? e.message : "Error desconocido al procesar la solicitud.";
    // Redirigir con mensaje de error
    return Response.redirect(`/admin/exchange?error=${encodeURIComponent(errorMsg)}`), 303;
  }
}

// ----------------------
// Manejo de Mensajes de URL
// ----------------------
const urlSuccess = Astro.url.searchParams.get("success");
const urlError = Astro.url.searchParams.get("error");

if (urlSuccess === "1") {
  message = { type: 'success', text: "Tasa de cambio actualizada correctamente." };
} else if (urlError) {
  message = { type: 'error', text: decodeURIComponent(urlError) };
}

---
<Layout title="Actualizar Tasa de Cambio">
  <div class="flex min-h-screen bg-gray-50 w-full">
    <Sidebar activePage="update-rate" />

    <main class="flex-1 ml-64 p-8 overflow-y-auto">
      <div class="max-w-3xl mx-auto space-y-6">
        <h1 class="text-3xl font-bold text-gray-900">Actualizar Tasa de Cambio (USD/COP)</h1>
        <p class="text-gray-600 mt-1">Registra el último valor del dólar para que los cálculos del portafolio se actualicen.</p>

        {message && (
          <div class={`p-4 rounded-lg border ${message.type === 'success' ? 'bg-green-50 border-green-200' : 'bg-red-50 border-red-200'}`}>
            <p class={`text-sm font-medium ${message.type === 'success' ? 'text-green-800' : 'text-red-800'}`}>
              {message.text}
            </p>
          </div>
        )}

        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Tasa Registrada Actualmente</h3>
            <p class="text-2xl font-bold text-gray-900 mt-2">
                $1 USD = ${latestRate} COP
            </p>
            <p class="text-sm text-gray-500 mt-1">Fecha de Registro: {latestDate}</p>
        </div>


        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <form method="POST" class="space-y-4">
                <div>
                    <label for="rate_date" class="block text-sm font-medium text-gray-700">Fecha de la Tasa</label>
                    <input 
                        type="date" 
                        id="rate_date" 
                        name="rate_date" 
                        required 
                        class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2 focus:ring-blue-500 focus:border-blue-500"
                        value={new Date().toISOString().slice(0, 10)}
                    />
                </div>
                <div>
                    <label for="new_rate" class="block text-sm font-medium text-gray-700">Valor USD a COP (Ej: 3950.50)</label>
                    <input 
                        type="number" 
                        id="new_rate" 
                        name="new_rate" 
                        step="0.01" 
                        min="0.01"
                        required 
                        placeholder="Ejemplo: 3950.50"
                        class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2 focus:ring-blue-500 focus:border-blue-500"
                    />
                </div>
                <button 
                    type="submit" 
                    class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500"
                >
                    Guardar Nueva Tasa
                </button>
            </form>
        </div>
      </div>
    </main>
  </div>
</Layout>