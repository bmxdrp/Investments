---
import Layout from "@layouts/default.astro";
import { sql } from "@lib/db";
import Sidebar from "@components/sidebar.astro";

const userId = Astro.locals.userId;

if (!userId) {
  return Astro.redirect("/auth/login?returnTo=/admin/history");
}

// Obtener todos los movimientos agrupados por mes
const movements = await sql`
  SELECT 
    'contribution' AS type,
    c.date,
    c.amount,
    c.currency,
    c.note,
    a.name as account_name,
    TO_CHAR(c.date, 'YYYY-MM') as month_key,
    TO_CHAR(c.date, 'Month YYYY') as month_label
  FROM contributions c
  JOIN accounts a ON c.account_id = a.id
  
  UNION ALL
  
  SELECT 
    'withdrawal' AS type,
    w.date,
    w.amount,
    w.currency,
    w.note,
    a.name as account_name,
    TO_CHAR(w.date, 'YYYY-MM') as month_key,
    TO_CHAR(w.date, 'Month YYYY') as month_label
  FROM withdrawals w
  JOIN accounts a ON w.account_id = a.id
  
  ORDER BY date DESC;
`;

// Agrupar movimientos por mes
const movementsByMonth = movements.reduce((acc, mov) => {
  const monthKey = mov.month_key;
  if (!acc[monthKey]) {
    acc[monthKey] = {
      label: mov.month_label,
      movements: [],
      totalContributions: 0,
      totalWithdrawals: 0
    };
  }
  
  acc[monthKey].movements.push(mov);
  
  if (mov.type === 'contribution') {
    acc[monthKey].totalContributions += Number(mov.amount);
  } else {
    acc[monthKey].totalWithdrawals += Number(mov.amount);
  }
  
  return acc;
}, {} as Record<string, any>);

// Convertir a array y ordenar por mes (más reciente primero)
const monthsArray = Object.entries(movementsByMonth)
  .sort(([a], [b]) => b.localeCompare(a))
  .map(([key, data]) => ({ key, ...data }));

// Calcular totales generales
const totalContributions = movements
  .filter(m => m.type === 'contribution')
  .reduce((sum, m) => sum + Number(m.amount), 0);

const totalWithdrawals = movements
  .filter(m => m.type === 'withdrawal')
  .reduce((sum, m) => sum + Number(m.amount), 0);

const netMovement = totalContributions - totalWithdrawals;
---

<Layout title="Historial de Movimientos">
  <div class="flex min-h-screen bg-gray-50 w-full">
    <!-- SIDEBAR -->
    <Sidebar activePage="history" />

    <!-- MAIN CONTENT -->
    <main class="flex-1 ml-64 p-8 overflow-y-auto">
      <div class="max-w-6xl mx-auto space-y-6">
        <!-- Header -->
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-3xl font-bold text-gray-900">Historial de Movimientos</h1>
            <p class="text-gray-600 mt-1">Todos tus aportes y retiros organizados por mes</p>
          </div>
        </div>

        <!-- Summary Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- Total Contributions -->
          <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-medium text-gray-600">Total Aportes</p>
                <p class="text-2xl font-bold text-green-600 mt-2">
                  ${(totalContributions / 1000000).toFixed(2)}M
                </p>
                <p class="text-xs text-gray-500 mt-1">Histórico</p>
              </div>
              <div class="p-3 bg-green-100 rounded-lg">
                <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11l5-5m0 0l5 5m-5-5v12"/>
                </svg>
              </div>
            </div>
          </div>

          <!-- Total Withdrawals -->
          <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-medium text-gray-600">Total Retiros</p>
                <p class="text-2xl font-bold text-red-600 mt-2">
                  ${(totalWithdrawals / 1000000).toFixed(2)}M
                </p>
                <p class="text-xs text-gray-500 mt-1">Histórico</p>
              </div>
              <div class="p-3 bg-red-100 rounded-lg">
                <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 13l-5 5m0 0l-5-5m5 5V6"/>
                </svg>
              </div>
            </div>
          </div>

          <!-- Net Movement -->
          <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-medium text-gray-600">Movimiento Neto</p>
                <p class={`text-2xl font-bold mt-2 ${netMovement >= 0 ? 'text-blue-600' : 'text-orange-600'}`}>
                  {netMovement >= 0 ? '+' : ''}{(netMovement / 1000000).toFixed(2)}M
                </p>
                <p class="text-xs text-gray-500 mt-1">Aportes - Retiros</p>
              </div>
              <div class={`p-3 rounded-lg ${netMovement >= 0 ? 'bg-blue-100' : 'bg-orange-100'}`}>
                <svg class={`w-8 h-8 ${netMovement >= 0 ? 'text-blue-600' : 'text-orange-600'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                </svg>
              </div>
            </div>
          </div>
        </div>

        <!-- Movements by Month -->
        <div class="space-y-6">
          {monthsArray.map(month => {
            const netMonth = month.totalContributions - month.totalWithdrawals;
            return (
              <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                <!-- Month Header -->
                <div class="bg-linear-to-r from-slate-800 to-slate-700 px-6 py-4">
                  <div class="flex items-center justify-between">
                    <div>
                      <h3 class="text-xl font-bold text-white capitalize">
                        {month.label.trim()}
                      </h3>
                      <p class="text-slate-300 text-sm mt-1">
                        {month.movements.length} {month.movements.length === 1 ? 'movimiento' : 'movimientos'}
                      </p>
                    </div>
                    <div class="text-right">
                      <p class="text-sm text-slate-300">Balance del mes</p>
                      <p class={`text-2xl font-bold ${netMonth >= 0 ? 'text-green-400' : 'text-red-400'}`}>
                        {netMonth >= 0 ? '+' : ''}{netMonth.toLocaleString('es-CO', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}
                      </p>
                    </div>
                  </div>

                  <!-- Month Summary -->
                  <div class="grid grid-cols-2 gap-4 mt-4 pt-4 border-t border-slate-600">
                    <div>
                      <p class="text-xs text-slate-400">Aportes</p>
                      <p class="text-lg font-semibold text-green-400">
                        +{month.totalContributions.toLocaleString('es-CO', { minimumFractionDigits: 2 })}
                      </p>
                    </div>
                    <div>
                      <p class="text-xs text-slate-400">Retiros</p>
                      <p class="text-lg font-semibold text-red-400">
                        -{month.totalWithdrawals.toLocaleString('es-CO', { minimumFractionDigits: 2 })}
                      </p>
                    </div>
                  </div>
                </div>

                <!-- Movements List -->
                <div class="divide-y divide-gray-100">
                  {month.movements.map((mov: any) => (
                    <div class="px-6 py-4 hover:bg-gray-50 transition">
                      <div class="flex items-center justify-between">
                        <div class="flex items-center gap-4 flex-1">
                          <!-- Icon -->
                          <div class={`p-3 rounded-lg ${mov.type === 'withdrawal' ? 'bg-red-100' : 'bg-green-100'}`}>
                            {mov.type === 'withdrawal' ? (
                              <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 13l-5 5m0 0l-5-5m5 5V6"/>
                              </svg>
                            ) : (
                              <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11l5-5m0 0l5 5m-5-5v12"/>
                              </svg>
                            )}
                          </div>

                          <!-- Details -->
                          <div class="flex-1">
                            <div class="flex items-center gap-3">
                              <p class="font-semibold text-gray-900 capitalize">
                                {mov.type === 'withdrawal' ? 'Retiro' : 'Aporte'}
                              </p>
                              <span class="text-xs px-2 py-1 bg-gray-100 text-gray-600 rounded-full font-medium">
                                {mov.account_name}
                              </span>
                            </div>
                            <div class="flex items-center gap-4 mt-1">
                              <p class="text-sm text-gray-500">
                                {new Date(mov.date).toLocaleDateString('es-CO', { 
                                  weekday: 'short',
                                  year: 'numeric',
                                  month: 'short',
                                  day: 'numeric'
                                })}
                              </p>
                              {mov.note && (
                                <p class="text-sm text-gray-500 italic">
                                  "{mov.note}"
                                </p>
                              )}
                            </div>
                          </div>

                          <!-- Amount -->
                          <div class="text-right">
                            <p class={`text-xl font-bold ${mov.type === 'withdrawal' ? 'text-red-600' : 'text-green-600'}`}>
                              {mov.type === 'withdrawal' ? '-' : '+'}
                              {Number(mov.amount).toLocaleString('es-CO', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}
                            </p>
                            <p class="text-xs text-gray-500 mt-1">{mov.currency}</p>
                          </div>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            );
          })}
        </div>

        {monthsArray.length === 0 && (
          <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-12 text-center">
            <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <h3 class="text-xl font-semibold text-gray-900 mb-2">No hay movimientos registrados</h3>
            <p class="text-gray-600 mb-6">Comienza agregando tu primer aporte o retiro</p>
            <div class="flex gap-4 justify-center">
              <a href="/admin/contribute" class="px-6 py-3 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700 transition">
                Agregar Fondos
              </a>
              <a href="/admin/withdraw" class="px-6 py-3 bg-gray-100 text-gray-700 rounded-lg font-medium hover:bg-gray-200 transition">
                Retirar Fondos
              </a>
            </div>
          </div>
        )}
      </div>
    </main>
  </div>
</Layout>